{
  "name": "@portabletext/react",
  "version": "6.2.0",
  "description": "Render Portable Text with React",
  "keywords": [
    "portable-text"
  ],
  "homepage": "https://github.com/portabletext/react-portabletext#readme",
  "bugs": {
    "url": "https://github.com/portabletext/react-portabletext/issues"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/portabletext/react-portabletext.git"
  },
  "files": [
    "dist",
    "!dist/stats.html"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prebuild:demo": "pnpm clean",
    "build:demo": "vite build demo --config=./vite.config.demo.ts --base=/react-portabletext/",
    "clean": "rimraf dist coverage demo/dist .nyc_output",
    "dev": "vite demo --config=./vite.config.demo.ts",
    "format": "oxfmt .",
    "lint": "oxlint --type-aware --type-check --deny-warnings --report-unused-disable-directives",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish",
    "start": "pnpm dev",
    "test": "vitest",
    "typegen": "(cd test/typegen && sanity schema extract && sanity typegen generate)",
    "type-check": "tsc --noEmit -p tsconfig.dist.json"
  },
  "dependencies": {
    "@portabletext/toolkit": "^5.0.2",
    "@portabletext/types": "^4.0.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/tsconfig": "^2.1.0",
    "@sanity/tsdown-config": "^0.6.1",
    "@sanity/ui": "^3.2.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.28.0",
    "esbuild-register": "^3.6.0",
    "groq": "^5.25.1",
    "leaflet": "^1.9.4",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-is": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "react-refractor": "^4.0.0",
    "refractor": "^5.0.0",
    "rimraf": "^5.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sanity": "^5.25.1",
    "styled-components": "npm:@sanity/css-in-js@6.2.1",
    "tsdown": "^0.22.0",
    "typescript": "5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "react": "^18.2 || ^19"
  },
  "lint-staged": {
    "*": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "packageManager": "pnpm@10.33.4"
}
